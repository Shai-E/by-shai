/* ===========================================
   by-shai.net — Shai Eliav Developer Portfolio
   Redesigned 2026
   =========================================== */

/* ---------- Design tokens ---------- */
:root {
  --color-bg:          #0a0a0f;
  --color-surface:     #12121a;
  --color-surface-2:   #1a1a26;
  --color-border:      #2a2a3a;
  --color-text:        #e4e4ed;
  --color-text-muted:  #8888a0;
  --color-accent:      #6c63ff;
  --color-accent-hover:#857eff;
  --color-accent-glow: rgba(108, 99, 255, 0.15);
  --color-green:       #4ecdc4;
  --color-orange:      #ff9f43;
  --color-red:         #ff6b6b;

  --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

  --space-xs:  0.25rem;
  --space-sm:  0.5rem;
  --space-md:  1rem;
  --space-lg:  2rem;
  --space-xl:  4rem;
  --space-2xl: 6rem;

  --radius:    12px;
  --radius-sm: 8px;
  --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --nav-height: 64px;
}

/* ---------- Developer Theme Override ---------- */
body.dev-theme {
  --color-bg:         #000000;
  --color-surface:    #0a0a0a;
  --color-surface-2:  #111111;
  --color-border:     #1a3a1a;
  --color-text:       #00ff00;
  --color-text-muted: #00aa00;
  --color-accent:     #00ff00;
  --color-accent-hover: #33ff33;
  --color-accent-glow: rgba(0, 255, 0, 0.1);
  font-family: var(--font-mono) !important;
}

body.dev-theme * {
  font-family: var(--font-mono) !important;
}

/* ---------- Reset ---------- */
*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  scroll-padding-top: var(--nav-height);
}

body {
  font-family: var(--font-sans);
  background: var(--color-bg);
  color: var(--color-text);
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
  transition: background 0.5s, color 0.5s;
}

a {
  color: var(--color-accent);
  text-decoration: none;
  transition: color var(--transition);
}

a:hover { color: var(--color-accent-hover); }

img { max-width: 100%; display: block; }
ul { list-style: none; }

/* ---------- Utility ---------- */
.container {
  width: 100%;
  max-width: 1080px;
  margin-inline: auto;
  padding-inline: var(--space-lg);
}

.accent { color: var(--color-accent); }

/* ---------- Buttons ---------- */
.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-sm);
  padding: 0.75rem 1.75rem;
  border-radius: var(--radius-sm);
  font-weight: 600;
  font-size: 0.95rem;
  transition: all var(--transition);
  cursor: pointer;
  border: 2px solid transparent;
  text-decoration: none;
}

.btn--primary {
  background: var(--color-accent);
  color: #fff;
  border-color: var(--color-accent);
}

.btn--primary:hover {
  background: var(--color-accent-hover);
  border-color: var(--color-accent-hover);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(108, 99, 255, 0.3);
}

.btn--outline {
  background: transparent;
  color: var(--color-text);
  border-color: var(--color-border);
}

.btn--outline:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
  transform: translateY(-2px);
}

.btn--small {
  padding: 0.5rem 1.15rem;
  font-size: 0.85rem;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.btn--small svg {
  flex-shrink: 0;
}

/* ---------- Navigation ---------- */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--nav-height);
  z-index: 1000;
  background: rgba(10, 10, 15, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid transparent;
  transition: border-color var(--transition), background var(--transition);
}

.nav--scrolled {
  border-bottom-color: var(--color-border);
  background: rgba(10, 10, 15, 0.95);
}

.nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1080px;
  margin-inline: auto;
  padding-inline: var(--space-lg);
  height: 100%;
}

.nav__logo {
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--color-text);
  text-decoration: none;
  user-select: none;
}

.nav__logo:hover { color: var(--color-text); }

.nav__links {
  display: flex;
  gap: var(--space-lg);
}

.nav__links a {
  color: var(--color-text-muted);
  font-weight: 500;
  font-size: 0.9rem;
  transition: color var(--transition);
  position: relative;
}

.nav__links a::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0;
  width: 0; height: 2px;
  background: var(--color-accent);
  transition: width var(--transition);
}

.nav__links a:hover,
.nav__links a.active { color: var(--color-text); }

.nav__links a:hover::after,
.nav__links a.active::after { width: 100%; }

/* Hamburger */
.nav__toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--space-sm);
}

.nav__toggle span {
  display: block;
  width: 22px; height: 2px;
  background: var(--color-text);
  border-radius: 2px;
  transition: all var(--transition);
}

/* ---------- Hero ---------- */
.hero {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  padding-top: var(--nav-height);
  position: relative;
  overflow: hidden;
}

.hero__bg-glow {
  position: absolute;
  top: 20%; right: -10%;
  width: 600px; height: 600px;
  background: radial-gradient(circle, var(--color-accent-glow) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
  animation: glowPulse 8s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.1); }
}

.hero__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xl);
  align-items: center;
}

.hero__greeting {
  font-family: var(--font-mono);
  color: var(--color-accent);
  font-size: 1rem;
  margin-bottom: var(--space-sm);
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.2s;
}

.hero__name {
  font-size: clamp(2.5rem, 6vw, 4rem);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: var(--space-sm);
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.4s;
}

.hero__title {
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: var(--color-accent);
  font-weight: 600;
  margin-bottom: var(--space-md);
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.5s;
}

.hero__tagline {
  font-size: clamp(0.95rem, 1.5vw, 1.05rem);
  color: var(--color-text-muted);
  max-width: 520px;
  margin-bottom: var(--space-lg);
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.6s;
}

.hero__cta {
  display: flex;
  gap: var(--space-md);
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.8s;
}

.hero__scroll {
  position: absolute;
  bottom: var(--space-lg);
  left: 50%;
  transform: translateX(-50%);
  color: var(--color-text-muted);
  font-size: 1.5rem;
  animation: bounce 2s ease infinite;
}

/* Hero Code Window */
.hero__code {
  opacity: 0;
  animation: fadeUp 0.8s ease forwards 1s;
}

.hero__code-window {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
}

.hero__code-dots {
  display: flex;
  gap: 6px;
  padding: 12px 16px;
  background: var(--color-surface-2);
  border-bottom: 1px solid var(--color-border);
}

.hero__code-dots span {
  width: 10px; height: 10px;
  border-radius: 50%;
}

.hero__code-dots span:nth-child(1) { background: var(--color-red); }
.hero__code-dots span:nth-child(2) { background: var(--color-orange); }
.hero__code-dots span:nth-child(3) { background: var(--color-green); }

.hero__code-text {
  padding: var(--space-lg);
  font-family: var(--font-mono);
  font-size: 0.85rem;
  line-height: 1.8;
  color: var(--color-text-muted);
  white-space: pre;
  overflow-x: auto;
}

.hero__code-text .keyword { color: #c792ea; }
.hero__code-text .variable { color: #82aaff; }
.hero__code-text .string { color: #c3e88d; }
.hero__code-text .property { color: #f78c6c; }
.hero__code-text .bracket { color: #89ddff; }
.hero__code-text .punctuation { color: #89ddff; }

/* ---------- Sections ---------- */
.section {
  padding: var(--space-2xl) 0;
}

.section__title {
  font-size: clamp(1.6rem, 4vw, 2.2rem);
  font-weight: 700;
  margin-bottom: var(--space-xl);
  position: relative;
  display: inline-block;
}

.section__title::after {
  content: '';
  position: absolute;
  bottom: -8px; left: 0;
  width: 48px; height: 3px;
  background: var(--color-accent);
  border-radius: 3px;
}

/* ---------- Project Cards ---------- */
.projects {
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.projects__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--space-lg);
}

.project-card {
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: var(--space-lg);
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  display: flex;
  flex-direction: column;
}

.project-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  border-color: var(--color-accent);
}

.project-card__header {
  margin-bottom: var(--space-md);
}

.project-card__icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-accent-glow);
  border: 1px solid rgba(108, 99, 255, 0.2);
  border-radius: 12px;
  color: var(--color-accent);
  margin-bottom: var(--space-sm);
  transition: background var(--transition), border-color var(--transition);
}

.project-card:hover .project-card__icon {
  background: rgba(108, 99, 255, 0.2);
  border-color: var(--color-accent);
}

.project-card__icon--img {
  padding: 0;
  overflow: hidden;
  background: none;
  border-color: transparent;
}

.project-card__icon--img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 11px;
}

.project-card:hover .project-card__icon--img {
  background: none;
}

.project-card__name {
  font-size: 1.3rem;
  font-weight: 700;
}

.project-card__company {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--color-accent);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: var(--space-xs);
}

.project-card__desc {
  color: var(--color-text-muted);
  font-size: 0.95rem;
  margin-bottom: var(--space-md);
  flex-grow: 1;
}

.project-card__highlights {
  list-style: none;
  margin-bottom: var(--space-lg);
  padding: 0;
}

.project-card__highlights li {
  color: var(--color-text-muted);
  font-size: 0.88rem;
  padding-left: 1.2rem;
  position: relative;
  margin-bottom: var(--space-xs);
}

.project-card__highlights li::before {
  content: '▹';
  position: absolute;
  left: 0;
  color: var(--color-accent);
}

.project-card__tech {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: auto;
}

.tech-badge {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  padding: 0.3rem 0.7rem;
  background: var(--color-accent-glow);
  color: var(--color-accent);
  border-radius: 4px;
  border: 1px solid rgba(108, 99, 255, 0.2);
}

/* ---------- Skills ---------- */
.skills__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--space-lg);
}

.skill-group {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: var(--space-lg);
  transition: border-color var(--transition);
}

.skill-group:hover {
  border-color: var(--color-accent);
}

.skill-group__title {
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-accent);
  margin-bottom: var(--space-md);
}

.skill-group__items {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.skill-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  transition: background var(--transition);
  cursor: default;
  position: relative;
}

.skill-item:hover {
  background: var(--color-surface-2);
}

.skill-item__icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  color: var(--color-accent);
  display: flex;
  align-items: center;
  justify-content: center;
}

.skill-item__name {
  font-size: 0.95rem;
  font-weight: 500;
}

/* Skill tooltip */
.skill-item::after {
  content: attr(data-detail);
  position: absolute;
  bottom: 110%;
  left: 50%;
  transform: translateX(-50%) translateY(8px);
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-md);
  font-size: 0.78rem;
  color: var(--color-text-muted);
  white-space: nowrap;
  pointer-events: none;
  opacity: 0;
  transition: opacity var(--transition), transform var(--transition);
  z-index: 10;
}

.skill-item:hover::after {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ---------- Experience Timeline ---------- */
.experience {
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.timeline {
  position: relative;
  padding-left: var(--space-xl);
}

.timeline::before {
  content: '';
  position: absolute;
  left: 15px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--color-border);
}

.timeline__item {
  position: relative;
  margin-bottom: var(--space-xl);
}

.timeline__item:last-child {
  margin-bottom: 0;
}

.timeline__dot {
  position: absolute;
  left: calc(-1 * var(--space-xl) + 8px);
  top: 6px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--color-accent);
  border: 3px solid var(--color-bg);
  box-shadow: 0 0 0 2px var(--color-accent);
  z-index: 1;
}

.timeline__content {
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: var(--space-lg);
  transition: border-color var(--transition), transform var(--transition);
}

.timeline__content:hover {
  border-color: var(--color-accent);
  transform: translateX(4px);
}

.timeline__date {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--color-accent);
  letter-spacing: 0.05em;
}

.timeline__role {
  font-size: 1.15rem;
  font-weight: 700;
  margin-top: var(--space-xs);
  line-height: 1.4;
}

.timeline__company {
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--color-text-muted);
  margin-top: var(--space-xs);
  margin-bottom: var(--space-md);
}

.timeline__highlights {
  list-style: none;
  padding: 0;
}

.timeline__highlights li {
  color: var(--color-text-muted);
  font-size: 0.9rem;
  padding-left: 1.2rem;
  position: relative;
  margin-bottom: var(--space-xs);
}

.timeline__highlights li::before {
  content: '▹';
  position: absolute;
  left: 0;
  color: var(--color-accent);
}

/* ---------- About ---------- */
.about__content {
  max-width: 680px;
}

.about__text p {
  color: var(--color-text-muted);
  font-size: 1.05rem;
  margin-bottom: var(--space-md);
}

.about__text p:last-child {
  margin-bottom: 0;
}

.about__text strong {
  color: var(--color-text);
  font-weight: 600;
}

/* ---------- GitHub ---------- */
.github__card {
  display: flex;
  align-items: center;
  gap: var(--space-xl);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: var(--space-xl);
  transition: border-color var(--transition);
}

.github__card:hover {
  border-color: var(--color-accent);
}

.github__avatar {
  color: var(--color-text);
  flex-shrink: 0;
  transition: color var(--transition);
}

.github__avatar:hover {
  color: var(--color-accent);
}

.github__info h3 {
  font-family: var(--font-mono);
  font-size: 1.2rem;
  margin-bottom: var(--space-sm);
}

.github__info p {
  color: var(--color-text-muted);
  margin-bottom: var(--space-md);
}

/* GitHub hover tooltip (easter egg) */
.github__tooltip {
  position: absolute;
  top: -60px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--color-surface-2);
  border: 1px solid var(--color-accent);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-md);
  color: var(--color-accent);
  font-size: 0.85rem;
  white-space: nowrap;
  opacity: 0;
  transition: opacity var(--transition);
  pointer-events: none;
}

.github__tooltip.visible {
  opacity: 1;
}

/* ---------- Contact ---------- */
.contact__text {
  color: var(--color-text-muted);
  font-size: 1.05rem;
  max-width: 520px;
  margin-bottom: var(--space-xl);
}

.contact__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: var(--space-md);
}

.contact-card {
  display: block;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: var(--space-lg);
  transition: border-color var(--transition), transform var(--transition);
  text-decoration: none;
  color: var(--color-text);
}

.contact-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-2px);
  color: var(--color-text);
}

.contact-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: var(--color-accent-glow);
  border: 1px solid rgba(108, 99, 255, 0.2);
  border-radius: 12px;
  color: var(--color-accent);
  margin-bottom: var(--space-md);
  transition: background var(--transition), border-color var(--transition);
}

.contact-card:hover .contact-card__icon {
  background: rgba(108, 99, 255, 0.2);
  border-color: var(--color-accent);
}

.contact-card h4 {
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-text-muted);
  margin-bottom: var(--space-sm);
}

.contact-card p {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--color-accent);
}

/* ---------- Scroll Complete ---------- */
.scroll-complete {
  padding: var(--space-xl) 0;
  text-align: center;
  background: linear-gradient(to bottom, transparent, var(--color-accent-glow));
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.scroll-complete.visible {
  opacity: 1;
  transform: translateY(0);
}

.scroll-complete__text {
  font-size: 1.2rem;
  color: var(--color-text);
  margin-bottom: var(--space-sm);
  line-height: 1.6;
}

.scroll-complete__subtext {
  color: var(--color-accent);
  font-size: 1rem;
  margin-bottom: var(--space-lg);
}

/* ---------- In Stores ---------- */
.stores {
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.stores__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--space-lg);
}

.store-card {
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: var(--space-xl) var(--space-lg);
  text-align: center;
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  position: relative;
  overflow: hidden;
}

.store-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3);
  border-color: var(--color-accent);
}

.store-card__badge {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-orange);
  background: rgba(255, 159, 67, 0.1);
  border: 1px solid rgba(255, 159, 67, 0.25);
  border-radius: 4px;
  padding: 0.2rem 0.6rem;
  margin-bottom: var(--space-md);
}

.store-card__logo {
  width: 80px;
  height: 80px;
  border-radius: 18px;
  object-fit: cover;
  margin: 0 auto var(--space-md);
}

.store-card__name {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: var(--space-xs);
}

.store-card__category {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-accent);
  margin-bottom: var(--space-md);
}

.store-card__desc {
  color: var(--color-text-muted);
  font-size: 0.95rem;
  margin-bottom: var(--space-lg);
  line-height: 1.7;
}

.store-card__links {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
  justify-content: center;
}

/* ---------- Footer ---------- */
.footer {
  border-top: 1px solid var(--color-border);
  padding: var(--space-lg) 0;
  text-align: center;
}

.footer p {
  color: var(--color-text-muted);
  font-size: 0.85rem;
}

/* =============================================
   EASTER EGG STYLES
   ============================================= */

/* ---------- Terminal ---------- */
.terminal {
  position: fixed;
  bottom: 16px;
  right: 16px;
  width: 420px;
  max-width: calc(100vw - 32px);
  max-height: 360px;
  background: rgba(10, 10, 15, 0.95);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  z-index: 2000;
  display: flex;
  flex-direction: column;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(16px);
}

.terminal[hidden] { display: none; }

.terminal__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) var(--space-md);
  background: var(--color-surface-2);
  border-bottom: 1px solid var(--color-border);
  border-radius: var(--radius) var(--radius) 0 0;
}

.terminal__title {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--color-text-muted);
}

.terminal__close {
  background: none;
  border: none;
  color: var(--color-text-muted);
  font-size: 1.3rem;
  cursor: pointer;
  padding: 2px 6px;
  line-height: 1;
  transition: color var(--transition);
}

.terminal__close:hover { color: var(--color-red); }

.terminal__body {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-md);
  font-family: var(--font-mono);
  font-size: 0.82rem;
  line-height: 1.6;
}

.terminal__output {
  color: var(--color-green);
  white-space: pre-wrap;
  word-break: break-word;
  margin-bottom: var(--space-sm);
}

.terminal__input-line {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.terminal__prompt {
  color: var(--color-green);
  flex-shrink: 0;
}

.terminal__input {
  flex: 1;
  background: none;
  border: none;
  color: var(--color-green);
  font-family: var(--font-mono);
  font-size: 0.82rem;
  outline: none;
  caret-color: var(--color-green);
}

/* ---------- Developer Overlay ---------- */
.dev-overlay { display: none; }
.dev-overlay:not([hidden]) {
  display: flex;
  position: fixed;
  inset: 0;
  z-index: 3000;
  align-items: center;
  justify-content: center;
}

.dev-overlay__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
}

.dev-overlay__panel {
  position: relative;
  background: var(--color-surface);
  border: 1px solid var(--color-accent);
  border-radius: var(--radius);
  padding: var(--space-xl);
  width: 560px;
  max-width: 90vw;
  max-height: 80vh;
  overflow-y: auto;
  font-family: var(--font-mono);
  box-shadow: 0 0 80px var(--color-accent-glow);
}

.dev-overlay__panel h2 {
  color: var(--color-accent);
  font-size: 1.3rem;
  margin-bottom: var(--space-sm);
}

.dev-overlay__welcome {
  color: var(--color-text-muted);
  font-size: 0.9rem;
  margin-bottom: var(--space-md);
}

.dev-overlay__commands {
  color: var(--color-text-muted);
  font-size: 0.85rem;
  margin-bottom: var(--space-md);
}

.dev-overlay__commands code {
  color: var(--color-accent);
}

.dev-overlay__body {
  color: var(--color-green);
  font-size: 0.85rem;
  white-space: pre-wrap;
  margin-bottom: var(--space-md);
  max-height: 200px;
  overflow-y: auto;
}

.dev-overlay__input-line {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  border-top: 1px solid var(--color-border);
  padding-top: var(--space-md);
}

.dev-overlay__prompt {
  color: var(--color-accent);
  flex-shrink: 0;
}

.dev-overlay__input {
  flex: 1;
  background: none;
  border: none;
  color: var(--color-accent);
  font-family: var(--font-mono);
  font-size: 0.85rem;
  outline: none;
  caret-color: var(--color-accent);
}

.dev-overlay__close {
  display: block;
  margin-top: var(--space-md);
  background: none;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  color: var(--color-text-muted);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  padding: var(--space-sm) var(--space-md);
  cursor: pointer;
  transition: border-color var(--transition), color var(--transition);
  width: 100%;
  text-align: center;
}

.dev-overlay__close:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
}

/* ---------- Game Modal ---------- */
.game-modal { display: none; }
.game-modal:not([hidden]) {
  display: flex;
  position: fixed;
  inset: 0;
  z-index: 3000;
  align-items: center;
  justify-content: center;
}

.game-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
}

.game-modal__panel {
  position: relative;
  background: var(--color-surface);
  border: 1px solid var(--color-accent);
  border-radius: var(--radius);
  padding: var(--space-lg);
  text-align: center;
}

.game-modal__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
  font-weight: 700;
}

.game-modal__close {
  background: none;
  border: none;
  color: var(--color-text-muted);
  font-size: 1.3rem;
  cursor: pointer;
  transition: color var(--transition);
}

.game-modal__close:hover { color: var(--color-red); }

.game-modal__subtitle {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--color-text-muted);
  margin-bottom: var(--space-md);
}

#snakeCanvas {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  display: block;
  margin: 0 auto var(--space-sm);
}

.game-modal__controls {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--color-text-muted);
}

/* ---------- Achievement Toast ---------- */
.achievement-toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(100px);
  background: var(--color-surface);
  border: 1px solid var(--color-accent);
  border-radius: var(--radius);
  padding: var(--space-md) var(--space-lg);
  display: flex;
  align-items: center;
  gap: var(--space-md);
  z-index: 4000;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: none;
}

.achievement-toast[hidden] {
  display: flex;
}

.achievement-toast.show {
  transform: translateX(-50%) translateY(0);
}

.achievement-toast__icon {
  font-size: 1.5rem;
}

.achievement-toast__label {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-accent);
}

.achievement-toast__name {
  font-weight: 700;
  font-size: 0.95rem;
}

/* ---------- Recruiter Popup ---------- */
.recruiter-popup {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 2000;
  animation: slideInUp 0.4s ease;
}

.recruiter-popup[hidden] { display: none; }

.recruiter-popup__content {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: var(--space-lg);
  max-width: 280px;
  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
  position: relative;
}

.recruiter-popup__close {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  background: none;
  border: none;
  color: var(--color-text-muted);
  font-size: 1.2rem;
  cursor: pointer;
  transition: color var(--transition);
}

.recruiter-popup__close:hover { color: var(--color-red); }

.recruiter-popup__title {
  font-weight: 700;
  font-size: 1.1rem;
  margin-bottom: var(--space-sm);
}

.recruiter-popup__text {
  color: var(--color-text-muted);
  font-size: 0.9rem;
  margin-bottom: var(--space-sm);
}

.recruiter-popup__text:last-of-type {
  margin-bottom: var(--space-md);
}

/* ---------- Confetti (shake easter egg) ---------- */
.confetti-piece {
  position: fixed;
  width: 8px;
  height: 8px;
  border-radius: 2px;
  z-index: 5000;
  pointer-events: none;
  animation: confettiFall 2s ease forwards;
}

@keyframes confettiFall {
  0% { opacity: 1; transform: translateY(0) rotate(0deg); }
  100% { opacity: 0; transform: translateY(100vh) rotate(720deg); }
}

/* ---------- Shake Message ---------- */
.shake-message {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--color-surface);
  border: 1px solid var(--color-accent);
  border-radius: var(--radius);
  padding: var(--space-lg) var(--space-xl);
  text-align: center;
  z-index: 5000;
  animation: fadeUp 0.4s ease;
  font-size: 1.1rem;
  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
}

/* ---------- Animations ---------- */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
  40% { transform: translateX(-50%) translateY(-10px); }
  60% { transform: translateX(-50%) translateY(-5px); }
}

@keyframes slideInUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Fade-in on scroll */
.fade-in {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.fade-in.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ---------- Responsive ---------- */
@media (max-width: 768px) {
  .nav__toggle { display: flex; }

  .nav__links {
    position: fixed;
    top: var(--nav-height);
    left: 0; right: 0;
    background: rgba(10, 10, 15, 0.98);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    flex-direction: column;
    align-items: center;
    padding: var(--space-lg);
    gap: var(--space-md);
    border-bottom: 1px solid var(--color-border);
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition: all var(--transition);
  }

  .nav__links.open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: all;
  }

  .nav__links a { font-size: 1.1rem; }

  .hero__grid {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .hero__content { order: 1; }
  .hero__code { order: 2; }

  .hero__tagline {
    margin-inline: auto;
  }

  .hero__cta {
    justify-content: center;
    flex-direction: column;
    width: 100%;
  }

  .hero__cta .btn {
    justify-content: center;
    text-align: center;
  }

  .projects__grid { grid-template-columns: 1fr; }
  .skills__grid { grid-template-columns: 1fr 1fr; }
  .contact__grid { grid-template-columns: 1fr; }

  .github__card {
    flex-direction: column;
    text-align: center;
  }

  .timeline { padding-left: var(--space-lg); }
  .timeline::before { left: 11px; }
  .timeline__dot {
    left: calc(-1 * var(--space-lg) + 4px);
    width: 14px; height: 14px;
  }

  .terminal { width: calc(100vw - 32px); right: 16px; }

  .skill-item::after { display: none; }
}

@media (max-width: 480px) {
  .container { padding-inline: var(--space-md); }
  .section { padding: var(--space-xl) 0; }
  .skills__grid { grid-template-columns: 1fr; }
}
